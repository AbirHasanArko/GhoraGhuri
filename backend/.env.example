# GhoraGhuri Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Application ───────────────────────────────────────────
DEBUG=false
SECRET_KEY=change-me-to-a-secure-random-string

# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ghoraghuri

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT ───────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-production
JWT_EXPIRY_HOURS=72

# ── bdapps API Credentials ────────────────────────────────
# Get these from https://dev.bdapps.com after registering your app
BDAPPS_APP_ID=
BDAPPS_PASSWORD=
BDAPPS_BASE_URL=https://developer.bdapps.com

# ── Economy ───────────────────────────────────────────────
ROUTE_CHARGE_BDT=2.0
COIN_TO_BDT_RATE=0.1
MIN_REDEEM_COINS=50
